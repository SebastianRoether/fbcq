C
C
C
      SUBROUTINE GDTEXT(IX,IY,TEXT,NTEXT,ISZE)
      CHARACTER*1 TEXT(NTEXT)
      COMMON/GSC/ICON(20),INTI(100),IPTSI(100),INTO(100),IPTSO(100)
C
C     ZEICHENGROESSE WAEHLEN
C
      ICON(1)=12
      ICON(2)=1
      IPTSI(1)=0
      IPTSI(2)=ISZE
      CALL GSX(ICON,INTI,IPTSI,INTO,IPTSO)
C
C     ZEICHENKETTE SCHREIBEN
C
      ICON(1)=8
      ICON(2)=1
      ICON(4)=NTEXT
      DO 10 I=1,NTEXT
      INTI(I)=TEXT(I)
 10   CONTINUE
      IPTSI(1)=IX
      IPTSI(2)=IY
      CALL GSX(ICON,INTI,IPTSI,INTO,IPTSO)
      RETURN
      END
