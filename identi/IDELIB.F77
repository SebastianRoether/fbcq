C
      SUBROUTINE XQRLSR(C,LC,A,LA,M,B,LB,N,WKSP,CV,SV,IPOS0,INFO)
C
C     ZWECK: REDUKTION DES GLEICHUNGSSYSTEMS,FALLS BESTIMMTE KOPPEL-
C     ELEMENTE BEKANNT SIND (QRLS-VARIANTE)
C
C     EINGABEPARAMETER:
C     IPOS0 - FELD DERSELBEN DIMENSION WIE DIE LOESUNG C. IST DAS
C             ELEMENT C(I,J)=0. BEKANNT, DANN IST IPOS0(I,J)=1 ZU UEBER-
C             GEBEN
C     WKSP  - HILFSFELD DER DIMENSION (M,M)
C     N     - ANZAHL DER SPALTEN DER RECHTEN SEITE
C     LB    - FUEHRENDE DIMENSION DES FELDES B
C     B     - RECHTE SEITE DES GELICHUNGSSYSTEMS
C     M     - ZEILEN- UND SPALTENZAHL VON A UND WKSP
C     LA    - FUEHRENDE DIMENSION DER MATRIX A
C     A     - SYSTEMMATRIX A IND DREIECKSGESTALT
C     LC    - FUEHRENDE DIMENSION DER MATRIX C 
C     CV    - VEKTOR MIT DREHUNGS-KOSINUS
C     SV    - VEKTOR MIT DREHUNGS-SINUS
C
C     AUSGABEPARAMETER:
C     C     - REDUZIERTE LOESUNG
C
C     ROETHER/3/86
C
      DIMENSION A(LA,M),B(LB,N),C(LC,N),WKSP(LA,M),IPOS0(LB,N)      
      DIMENSION CV(M),SV(M),CVW(38),SVW(38)
      LOGICAL ISAME
C
C     FUER JEDE SPALTE DER LOESUNG GETRENNTE GLEICHUNGSSYSTEME
C
      DO 1000 J=1,N
C
C     PRUEFE, OB RECHNUNG NOTWENDIG
C
         ISAME=.FALSE.
         IF(J.GT.1) THEN
            ISAME=.TRUE.
            DO 50 I=1,M
               IF(IPOS0(I,J).NE.IPOS0(I,J-1)) ISAME=.FALSE.
 50         CONTINUE
         END IF
C
C        SCHLEIFE UEBER ALLE SPALTEN DER MATRIX WKSP
C
         IF(.NOT.ISAME) THEN
            DO 60 I=1,M
               CALL VVCOPY(WKSP(1,I),A(1,I),M)
 60         CONTINUE
            CALL VVCOPY(CVW,CV,M)
            CALL VVCOPY(SVW,SV,M)
            ICNT=0
            DO 100 I=1,M
               IF(IPOS0(I,J).NE.1) THEN
                  ICNT=ICNT+1
                  IF(I.GT.ICNT) THEN
                     CALL SCHEX(WKSP,LA,M,ICNT,I,B(1,J),LB,1,CVW,SVW,1)
                  END IF
               END IF
 100        CONTINUE
            MRED=ICNT
         END IF
C
C        LOESE REDUZIERTES GLEICHUNGSSYSTEM
C
         CALL STRSL1(WKSP,LA,MRED,B(1,J),INFO)
         IF(INFO.NE.0) GO TO 9999
         ICNT=MRED
         DO 300 I=1,M
            I1=M+1-I
            IF(IPOS0(I1,J).NE.1) THEN
               C(I1,J)=B(ICNT,J)
               ICNT=ICNT-1
            ELSE            
               C(I1,J)=0.
            END IF
 300     CONTINUE
 1000 CONTINUE
 9999 CONTINUE
      RETURN
      END
C
C
C
      SUBROUTINE XQRIVR(C,LC,R,LR,A,LA,M,B,LB,N,WKSP,IW,CV,SV,IPOS0,INF)
C
C     ZWECK: REDUKTION DES GLEICHUNGSSYSTEMS,FALLS BESTIMMTE KOPPEL-
C     ELEMENTE BEKANNT SIND (QRIV-VARIANTE)
C
C     EINGABEPARAMETER:
C     IPOS0 - FELD DERSELBEN DIMENSION WIE DIE LOESUNG C. IST DAS
C             ELEMENT C(I,J)=0. BEKANNT, DANN IST IPOS0(I,J)=1 ZU UEBER-
C             GEBEN
C     IW    - HILFSFELD DER DIMENSION M
C     WKSP  - HILFSFELD DER DIMENSION (M,M+N)
C     N     - ANZAHL DER SPALTEN DER RECHTEN SEITE
C     LB    - FUEHRENDE DIMENSION DES FELDES B
C     B     - RECHTE SEITE DES GELICHUNGSSYSTEMS
C     M     - ZEILEN- UND SPALTENZAHL VON A UND WKSP
C     LA    - FUEHRENDE DIMENSION DER MATRIX A
C     A     - SYSTEMMATRIX A                     
C     LR    - FUEHRENDE DIMENSION DES CHOLESKY-FAKTORS R
C     R     - CHOLESKY-FAKTOR R
C     LC    - FUEHRENDE DIMENSION DER MATRIX C 
C     CV    - VEKTOR MIT DREHUNGS-KOSINUS
C     SV    - VEKTOR MIT DREHUNGS-SINUS
C
C     AUSGABEPARAMETER:
C     C     - REDUZIERTE LOESUNG
C
C     ROETHER/3/86
C
      DIMENSION A(LA,M),B(LB,N),C(LC,N),WKSP(LA,M),IPOS0(LB,N),IW(M)
      DIMENSION R(LR,M)
      DIMENSION CV(M),SV(M),CVW(38),SVW(38)
      LOGICAL ISAME
C
C     FUER JEDE SPALTE DER LOESUNG GETRENNTE GLEICHUNGSSYSTEME
C
      M1=M+1
      M2=M1+M
      DO 1000 J=1,N
C
C     PRUEFE, OB RECHNUNG NOTWENDIG
C
         ISAME=.FALSE.
         IF(J.GT.1) THEN
            ISAME=.TRUE.
            DO 50 I=1,M
               IF(IPOS0(I,J).NE.IPOS0(I,J-1)) ISAME=.FALSE.
 50         CONTINUE
         END IF
C
C        SCHLEIFE UEBER ALLE SPALTEN DER MATRIX WKSP
C
         CALL VVCOPY(WKSP(1,M2),B(1,J),M)
         IF(.NOT.ISAME) THEN
            DO 60 I=1,M
               CALL VVCOPY(WKSP(1,I),R(1,I),M)
               CALL VVCOPY(WKSP(1,I+M),A(1,I),M)
 60         CONTINUE
            CALL VVCOPY(CVW,CV,M)
            CALL VVCOPY(SVW,SV,M)
            ICNT=0
            DO 100 I=1,M
               IF(IPOS0(I,J).NE.1) THEN
                  ICNT=ICNT+1
                  IF(I.GT.ICNT) THEN
                     CALL SCHEX(WKSP,LA,M,ICNT,I,WKSP(1,M1),LA,M1,
     *               CVW,SVW,1)
                  END IF
               END IF
 100        CONTINUE
            MRED=ICNT
            ICNT=0
C
C           STREICHE SPALTEN
C
            DO 200 I=1,M
               IF(IPOS0(I,J).NE.1) THEN
                  ICNT=ICNT+1
                  CALL VVCOPY(WKSP(1,M+ICNT),WKSP(1,M+I),M)
               END IF
 200        CONTINUE
         END IF
C
C        LOESE REDUZIERTES GLEICHUNGSSYSTEM
C
         JOB=1
         IF(ISAME) JOB=2
         CALL MIMPRD(WKSP(1,M2),LA,WKSP(1,M1),LA,MRED,WKSP(1,M2),LA,1,
     *   IW,JOB,INF)
         IF(INF.NE.0) GO TO 9999
         ICNT=MRED
         DO 300 I=1,M
            I1=M+1-I
            IF(IPOS0(I1,J).NE.1) THEN
               C(I1,J)=WKSP(ICNT,M2)
               ICNT=ICNT-1
            ELSE            
               C(I1,J)=0.
            END IF
 300     CONTINUE
 1000 CONTINUE
 9999 CONTINUE
      RETURN
      END
