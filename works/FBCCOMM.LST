    299  c
    300  c
    301  c
    302        subroutine rinput(charac,cpval,wert,job)
    303  c
    304  c     Zweck:Handeingabe einer Real-Zahl. Ist sie verschieden von Null,
    305  c     dann wird sie dem eingelesenen Wert zugewiesen.
    306  c
    307  c     Eingabe:
    308  c     charac  - Character-Bezeichnung (30 Zeichen)
    309  c     cpval   - Physikalische Bezeichnung (4 Zeichen)
    310  c     wert    - Bisheriger Wert
    311  c     job     - 0: Keine Werte kleiner Null werden eingelesen
    312  c
    313  c     Ausgabe:
    314  c     wert    - Neuer Wert
    315  c
    316  c     Autor: Friedemann Roether
    317  c     Letzte Aenderung: 25.05.1987
    318  c
    319        real*8 wert,wert1,wert2
    320        character*30 charac
    321        character*4 cpval
    322        character*1 c
 

                                                                        PAGE   8
                                                                        04-24-99
                                                                        16:59:35

  Line#  Source Line          Microsoft FORTRAN Optimizing Compiler Version 4.00

    323   10   continue
    324        wert2=wert
    325        write(*,'(a1,a30,a1,a4,a5,f10.4,a2\)') ' ',charac,' ',cpval,
    326       *')   (',wert,'):'
    327        read(*,'(g18.10)',err=20) wert1
    328        go to 30
    329   20   continue
    330        c='J'
    331        call cisdin('Wert behalten <J> oder zu Null setzen <N> (J/N)',c)
    332        if(c.eq.'N') wert=0.d00
    333        call lclear
    334        go to 40
    335   30   continue
    336        if(wert1.ne.0.d0) then
    337         wert=wert1
    338         if(dabs(wert).lt.1.d-5.and.wert.ne.0.d00) wert=dnint(1.d10*wert)
    339         if(job.eq.0.and.wert1.lt.0.d00) wert=0.d00
    340        end if
    341   40   continue
    342        call lclear
    343        if(wert2.ne.wert) go to 10
    344        write(*,'(a1,a30,a1,a4,a5,f10.4)') ' ',charac,' ',cpval,
    345       *'):   ',wert
    346        return
    347        end


