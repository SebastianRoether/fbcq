     74  c
     75        do 115 i=1,16
     76           if(name(i:i).eq.' '.or.name(i:i).eq.'.') then
     77              nfbc=i
     78              go to 120
     79           end if
     80   115  continue
     81        nfbc=17
     82   120  continue
     83        if(nfbc.le.1) go to 1000
