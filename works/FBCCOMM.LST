     10        subroutine diskio(cbez,ctyu,ci,cs,cd,yanf,uanf,len,t,y,u,
     11       *yend,uend,pglw,pver,nk,n,id,a,b,rho,q,r,dopt,kmax,nou,job,if)
     12  c
     13  c     Zweck: Transfer der Datenbank zwischen Speichermedium und
     14  c     dem Programm fbc (Reglerparameteroptimierung)
     15  c
     16  c     Eingabeparameter:
