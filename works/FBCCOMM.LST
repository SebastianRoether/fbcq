     86       *(name(4:4).eq.' '.or.name(4:4).eq.':')) then
     87           if(job.ne.1) go to 100
     88           name(4:20)=':                '
     89           ex=.false.
     90           go to 125
     91        end if
     92        name(nfbc:nfbc+3)='.fbc'
