    420  c
    421        subroutine xyinpu(x,y,z,len,nki,ctyu)
    422  c
    423  c     Zweck: Eingabe gemessener Prozess-Wertetripel
    424  c     Werte knnen editiert, gelscht und berschrieben werden.
    425  c
    426  c     Eingabe:
    427  c     ctyu  - Character-Vektor (*4) mit physikalischen Einheiten
    428  c     len   - Anzahl bisher eingegebener Wertetripel
    429  c     nki   - Maximalanzahl der Wertetripel
    430  c     x,y,z - Bisheriger Vektoren x(Zeit), y(Sprungantwort) und
    431  c             z (Sprunganregung)
    432  c
    433  c     Ausgabe:
    434  c     len   - Neue Wertetripel-Anzahl
    435  c     x,y,z - Neue Vektoren
    436  c
    437  c     Autor: Friedemann Roether
    438  c     Letzte Aenderung:15.05.1987
    439  c
    440        implicit real*8(a-h,o-z)
    441        character*4 ctyu(3)
    442  c
    443  c     Zweck: Eingabe von len Datentripeln x(i),y(i),z(i)
    444  c
    445        dimension x(nki),y(nki),z(nki)
    446  c
    447        if(len.eq.0) go to 9
    448        icnt=0
    449  c
    450  c     Ausgabe bisher eingelesener Wertetripel
    451  c
    452   2    continue
    453        call adclr
 

                                                                        PAGE  11
                                                                        04-24-99
                                                                        16:59:35

  Line#  Source Line          Microsoft FORTRAN Optimizing Compiler Version 4.00

    454        write(*,5)
    455   5    format(' Ausgabe bisher eingelesener Wertetripel:')
    456        do 7 i=1,len
    457           write(*,8) i,x(i),ctyu(1),y(i),ctyu(2),z(i),ctyu(3)
    458   8       format(1x,i3,' -tes Tripel:',3(G14.6,A4))
    459   7    continue
    460   9    continue
    461        if(icnt.ne.1) write(*,30)
    462   30   format(
    463       *' Bitte bertragen Sie nun etwa 8 (mindestens 4 ) Wertetripel'/
    464       *' (Relativzeit, Sprungantwort, ProzeÃeingangsgrÃe) mglichst'/
    465       *' exakt. Jedes Wertetripel ist durch Kommata zu trennen.     '/
    466       *' Beispiel fr eine Eingabe: 40,2.45,1.333 <RETURN>'/)
    467   40   continue
    468        len1=len+1
    469        if(len1.gt.nki) write(*,'(a31)') ' Max.Anz. Wertetripel erreicht.
    470        write(*,50) len1
    471   50   format(' ',i3,' -tes Tripel:'\)
    472        read(*,60,err=40) time,sprant,sprung
    473   60   format(3g18.10)
    474        if(dabs(time).lt.1.d-5.and.time.ne.0.d00) time=time*1.d10
    475        if(dabs(sprant).lt.1.d-5.and.sprant.ne.0.d00) sprant=sprant*1.d10
    476        if(dabs(sprung).lt.1.d-5.and.sprung.ne.0.d00) sprung=sprung*1.d10
    477        if(time.eq.0.d0.and.sprant.eq.0.d0.and.sprung.eq.0.d0) then
    478           if(len.eq.0) then
    479  c
    480  c     Erstes eingegebenes Wertetripel
    481  c
    482              x(1)=0.d00
    483              y(1)=0.d00
    484              z(1)=0.d00
    485              len=1
    486              i=1
    487              go to 40
    488           else
    489              icnt=icnt+1
    490              if(icnt.eq.1) go to 2
    491              if(icnt.eq.2) go to 999
    492           end if
    493        else
    494           call lclear
    495           write(*,8) len1,time,ctyu(1),sprant,ctyu(2),sprung,ctyu(3)
    496        end if
    497        icnt=0
    498  c
    499  c     Einsortieren der eingegebenen Werte
    500  c
    501        if(len.eq.0) then
    502           len=1
    503           i=1
    504           go to 100
    505        end if
    506        do 70 i=1,len
    507           if(sngl(x(i))-sngl(time)) 70,100,80
    508   70   continue
    509        if(len1.gt.nki) go to 2
 

                                                                        PAGE  12
                                                                        04-24-99
                                                                        16:59:35

  Line#  Source Line          Microsoft FORTRAN Optimizing Compiler Version 4.00

    510  c
    511  c     Neues Tripel ist letztes Tripel
    512  c
    513        len=len+1
    514        i=len
    515        go to 100
    516  c
    517  c     Werte nach Position i nach hinten verschieben
    518  c
    519   80   continue
    520        if(len1.gt.nki) go to 2
    521        i1=len-i+1
    522        do 90 j=1,i1
    523           j1=len-j+1
    524           x(j1+1)=x(j1)
    525           y(j1+1)=y(j1)
    526           z(j1+1)=z(j1)
    527   90   continue
    528        len=len+1
    529  c
    530  c     Wert an Position i einsortieren
    531  c
    532   100  continue
    533        if(sprung.ne.0.d0.or.sprant.ne.0.d0
    534       *.or.sngl(x(i)).ne.sngl(time))  then
    535           x(i)=time
    536           y(i)=sprant
    537           z(i)=sprung
    538        else
    539  c
    540  c     Wert an Position i ausketten
    541  c
    542           i1=i
    543           do 110 j=i1,len
    544              x(j)=x(j+1)
    545              y(j)=y(j+1)
    546              z(j)=z(j+1)
    547   110     continue
    548           len=len-1
    549        end if
    550        go to 40
    551   999  continue
    552        return
    553        end


